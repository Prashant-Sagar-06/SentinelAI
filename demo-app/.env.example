# SentinelAI Demo App Environment Configuration
# ==============================================
# Copy this file to .env and update values as needed

# MongoDB Connection URI
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/sentinelai_logs

# For MongoDB Atlas (replace with your credentials):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sentinelai_logs

# Server Port
PORT=3000
