# Backend API (Express)
NODE_ENV=production
PORT=4000
TRUST_PROXY=1
LOG_LEVEL=info
LOG_PRETTY=0

# Required
MONGO_URL=your_mongodb_atlas_url
REDIS_URL=your_redis_cloud_url
JWT_SECRET=your_jwt_secret
AI_ENGINE_URL=https://your-ai-engine-url

# CORS (comma-separated list). Example: https://app.sentinelai.com,https://staging.sentinelai.com
CORS_ORIGIN=https://your-frontend-url

# Required in production for worker -> backend broadcasts
INTERNAL_BROADCAST_SECRET=your_internal_broadcast_secret
