# Worker (BullMQ + Mongo)
NODE_ENV=production
LOG_LEVEL=info
LOG_PRETTY=0

# Required
MONGO_URL=your_mongodb_atlas_url
REDIS_URL=your_redis_cloud_url
AI_ENGINE_URL=https://your-ai-engine-url
BACKEND_API_URL=https://your-backend-url

# Required in production (must match backend)
INTERNAL_BROADCAST_SECRET=your_internal_broadcast_secret
