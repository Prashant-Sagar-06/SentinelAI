#############################################
# SentinelAI (PRODUCTION) Environment
#
# STRICT RULES:
# - No loopback/private hosts
# - No internal docker hostnames
# - No fallback defaults in code
# - Use public HTTPS URLs for all service-to-service calls
#############################################

# Backend API (Express)
PORT=4000
MONGO_URL=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
REDIS_URL=rediss://:<password>@<host>:<port>
JWT_SECRET=<generate-a-strong-secret>
AI_ENGINE_URL=https://ai.domain.com
INTERNAL_BROADCAST_SECRET=<generate-a-strong-internal-secret>
CORS_ORIGIN=https://app.domain.com

# Worker (BullMQ)
REDIS_URL=rediss://:<password>@<host>:<port>
AI_ENGINE_URL=https://ai.domain.com
BACKEND_API_URL=https://api.domain.com
INTERNAL_BROADCAST_SECRET=<same-as-backend>

# Frontend (Next.js / Vercel)
NEXT_PUBLIC_API_BASE_URL=https://api.domain.com

# AI Engine (FastAPI)
PORT=8000
# Allow ONLY the backend origin for CORS (browser access to AI engine is not required).
# Still required to avoid implicit wildcard CORS.
CORS_ORIGIN=https://api.domain.com

# Optional tunables (leave unset unless you know you need them)
# TRUST_PROXY=1
# RATE_LIMIT_PER_MINUTE=120
# LOG_LEVEL=info
# LOG_PRETTY=0
# ALERT_THRESHOLD_RISK=0.6
# AI_ENGINE_TIMEOUT_MS=4500
