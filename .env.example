# Shared
MONGO_URL=mongodb://mongo:27017/sentinelai
REDIS_URL=redis://redis:6379

# Backend API
BACKEND_PORT=4000
JWT_SECRET=dev_super_secret_change_me
# CORS allowlist. Comma-separate multiple origins.
# Example: CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN=http://localhost:3000
INTERNAL_BROADCAST_SECRET=dev_internal_secret_change_me
RATE_LIMIT_PER_MINUTE=120

# Data lifecycle (MongoDB TTL indexes)
# LOG_TTL_SECONDS=86400        # logs retained for 1 day
# METRICS_TTL_SECONDS=604800   # metrics retained for 7 days

# Copilot (optional)
COPILOT_PROVIDER=mock
XAI_API_KEY=
XAI_MODEL=grok-2-latest
COPILOT_RATE_LIMIT_PER_MINUTE=10

# Worker
AI_ENGINE_URL=http://ai-engine:8000
ALERT_THRESHOLD_RISK=0.6
BACKEND_API_URL=http://backend-api:4000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
