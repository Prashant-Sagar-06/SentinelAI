# SentinelAI AI Engine Environment Configuration
# ================================================
# Copy this file to .env and update values as needed

# MongoDB Connection URI
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/sentinelai_logs

# For MongoDB Atlas (replace with your credentials):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sentinelai_logs

# API Server Configuration (optional)
API_HOST=0.0.0.0
API_PORT=8000
